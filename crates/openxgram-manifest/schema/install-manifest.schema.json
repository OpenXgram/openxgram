{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openxgram.org/schema/install-manifest.schema.json",
  "title": "OpenXgram Install Manifest",
  "description": "xgram install 명령이 사용하는 패키지 설치 매니페스트 스키마",
  "type": "object",
  "required": ["manifest_version", "package"],
  "additionalProperties": false,
  "properties": {
    "manifest_version": {
      "type": "string",
      "description": "매니페스트 스키마 버전 (semver)",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "package": {
      "type": "object",
      "description": "패키지 메타데이터",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "패키지 이름 (소문자, 하이픈 허용)",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "version": {
          "type": "string",
          "description": "패키지 버전 (semver 또는 vMAJOR.MINOR.PATCH.BUILD)",
          "pattern": "^v?\\d+\\.\\d+\\.\\d+",
          "examples": ["0.1.0", "v0.1.0-alpha.1"]
        },
        "description": {
          "type": "string",
          "description": "패키지 설명",
          "maxLength": 256
        },
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "패키지 홈페이지 URL"
        },
        "license": {
          "type": "string",
          "description": "라이선스 식별자 (SPDX)",
          "examples": ["MIT", "Apache-2.0", "MIT OR Apache-2.0"]
        }
      }
    },
    "directories": {
      "type": "array",
      "description": "설치 시 생성할 디렉토리 목록",
      "default": [],
      "items": {
        "type": "object",
        "required": ["path"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "description": "디렉토리 경로 (~ 확장 지원)",
            "examples": ["~/.openxgram/data", "~/.openxgram/keystore"]
          },
          "mode": {
            "type": "string",
            "description": "Unix 파일 권한 (octal string)",
            "pattern": "^[0-7]{3,4}$",
            "examples": ["700", "755", "0700"]
          }
        }
      }
    },
    "hooks": {
      "type": "object",
      "description": "설치 라이프사이클 훅",
      "default": {},
      "additionalProperties": false,
      "properties": {
        "pre_install": {
          "type": "array",
          "description": "설치 전 실행할 쉘 명령 목록",
          "items": { "type": "string" }
        },
        "post_install": {
          "type": "array",
          "description": "설치 후 실행할 쉘 명령 목록",
          "items": { "type": "string" }
        },
        "pre_uninstall": {
          "type": "array",
          "description": "제거 전 실행할 쉘 명령 목록",
          "items": { "type": "string" }
        }
      }
    },
    "requirements": {
      "type": "object",
      "description": "설치 환경 요구사항",
      "default": {},
      "additionalProperties": false,
      "properties": {
        "rust_version": {
          "type": "string",
          "description": "최소 Rust 버전 (semver)",
          "pattern": "^\\d+\\.\\d+",
          "examples": ["1.75", "1.80.0"]
        },
        "binaries": {
          "type": "array",
          "description": "PATH에 있어야 하는 외부 바이너리 목록",
          "items": { "type": "string" },
          "examples": [["tailscale"], ["tailscale", "sqlite3"]]
        },
        "disk_mb": {
          "type": "integer",
          "description": "최소 필요 디스크 여유 공간 (MB)",
          "minimum": 0,
          "examples": [50, 200]
        }
      }
    }
  },
  "examples": [
    {
      "manifest_version": "1.0.0",
      "package": {
        "name": "openxgram",
        "version": "0.1.0-alpha.1",
        "description": "Memory & Credential Infrastructure for Multi-Agent Systems",
        "homepage": "https://github.com/OpenXgram/openxgram",
        "license": "MIT"
      },
      "directories": [
        { "path": "~/.openxgram", "mode": "700" },
        { "path": "~/.openxgram/keystore", "mode": "700" },
        { "path": "~/.openxgram/data", "mode": "700" }
      ],
      "hooks": {
        "post_install": ["xgram migrate", "xgram doctor"]
      },
      "requirements": {
        "rust_version": "1.75",
        "disk_mb": 50
      }
    }
  ]
}
